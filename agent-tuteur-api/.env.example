# ============================================================================
# Agent Tuteur Sénégal — variables d'environnement (exemple)
# Copier vers .env et ajuster. Toutes ont un défaut sûr pour la démo hors-ligne.
# ============================================================================

# --- Persistance relationnelle (étape 4) ---
# IMPORTANT (RLS) : en production, DATABASE_URL doit utiliser un rôle NON-superuser
# (CREATE ROLE ... NOSUPERUSER). Un superuser Postgres contourne TOUJOURS le Row
# Level Security (migration 0002_enable_rls), même avec FORCE ROW LEVEL SECURITY.
# Le POSTGRES_USER par défaut d'une image postgres officielle EST superuser :
# ne pas l'utiliser tel quel en production multi-tenant.
DATABASE_URL=postgresql+asyncpg://tuteur:tuteur@localhost:5432/tuteur

# --- Queue asynchrone (étape 6+) ---
REDIS_URL=redis://localhost:6379/0

# --- Vecteurs ---
# VECTOR_BACKEND: memory (défaut, sans serveur) | qdrant
VECTOR_BACKEND=memory
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=curriculum

# --- Embeddings ---
# EMBEDDING_BACKEND: light (défaut, déterministe hors-ligne) | bge_m3
EMBEDDING_BACKEND=bg_m3
EMBEDDING_DENSE_DIM=256

# --- LLM (chaîne de fallback : Mistral -> Ollama -> Mock) ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# LLM_BACKEND: auto (défaut, détecte selon clés dispo) | mistral | ollama | mock
LLM_BACKEND=auto

# --- API (étape 5+) ---
API_BASE_URL=http://localhost:8000
MAX_FILE_SIZE_MB=25
DEFAULT_TENANT=default
JWT_SECRET=change-me-in-production

# --- Recherche / RAG ---
RETRIEVAL_TOP_K=5
RRF_K=60
